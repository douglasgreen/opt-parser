{
  "modified": "2026-02-27",
  "name": "douglasgreen/opt-parser",
  "version": "1.0.0",
  "description": "Command-line option parser for PHP",
  "type": "module",
  "scripts": {
    "lint": "npm run lint:md && npm run lint:sh",
    "lint:md": "markdownlint '**/*.md'",
    "lint:sh": "shellcheck **/*.sh",
    "format": "prettier --write . && markdownlint '**/*.md' --fix"
  },
  "devDependencies": {
    "markdownlint-cli": "^0.47.0",
    "prettier": "^3.8.1",
    "prettier-plugin-sh": "^0.18.0",
    "shellcheck": "^4.1.0"
  }
}
